                toastCopySuccess: 'Copied to clipboard',\
                toastCopyFail: 'Copy failed',\
                toastDownload: 'Downloading',\
                modalTitle: 'User Guide',\
                modalContent: `\
                    <p>Welcome to the Prompt Grabber! A tool that reverse-engineers any image into high-quality drawing prompts.</p>\
                    <ul class="list-disc pl-5 space-y-2">\
                        <li><strong>Upload Image:</strong> Click to upload or drag and drop an image into the dashed box.</li>\
                        <li><strong>General Analysis:</strong> AI quickly captures the core subject and style.</li>\
                        <li><strong>Detailed Description:</strong> Uses 5 strict frameworks: Subject, Clothing, Action, Scene, and Camera.</li>\
                        <li><strong>Detailed Facial:</strong> Extremely detailed facial feature extraction.</li>\
                        <li><strong>Copy & Download:</strong> Easily copy the English prompt for tools like Midjourney, or download as TXT.</li>\
                    </ul>\
                `\
            \}\
        \};\
\
        function applyLanguage() \{\
            const t = i18n[currentLang];\
            document.getElementById('i18n-help').textContent = t.help;\
            document.getElementById('themeText').textContent = isDarkMode ? t.themeLight : t.themeDark;\
            document.getElementById('i18n-title').textContent = t.title;\
            document.getElementById('i18n-subtitle').textContent = t.subtitle;\
            document.getElementById('i18n-dropText').textContent = t.dropText;\
            document.getElementById('i18n-dropSubText').textContent = t.dropSubText;\
            document.getElementById('i18n-detailTitle').textContent = t.detailTitle;\
            document.getElementById('i18n-detailSub').textContent = t.detailSub;\
            document.getElementById('i18n-detailTooltip').textContent = t.detailTooltip;\
            document.getElementById('i18n-facialTitle').textContent = t.facialTitle;\
            document.getElementById('i18n-facialSub').textContent = t.facialSub;\
            document.getElementById('i18n-facialTooltip').textContent = t.facialTooltip;\
            document.getElementById('i18n-analyzeBtn').textContent = t.analyzeBtn;\
            document.getElementById('i18n-enPrompt').textContent = t.enPrompt;\
            document.getElementById('i18n-zhPrompt').textContent = t.zhPrompt;\
            document.getElementById('i18n-copyEn').textContent = t.copyEn;\
            document.getElementById('i18n-copyZh').textContent = t.copyZh;\
            document.getElementById('i18n-downloadBtn').textContent = t.downloadBtn;\
            document.getElementById('i18n-loading').textContent = t.loading;\
            \
            englishResult.placeholder = t.placeholderEn;\
            chineseResult.placeholder = t.placeholderZh;\
            \
            document.getElementById('i18n-modalTitle').textContent = t.modalTitle;\
            document.getElementById('i18n-modalContent').innerHTML = t.modalContent;\
        \}\
\
        langBtn.addEventListener('click', () => \{\
            currentLang = currentLang === 'zh-TW' ? 'en' : 'zh-TW';\
            langText.textContent = currentLang === 'zh-TW' ? 'EN' : '\uc0\u20013 ';\
            applyLanguage();\
        \});\
\
        // Init language on load\
        applyLanguage();\
\
        // --- Theme Toggle ---\
        themeBtn.addEventListener('click', () => \{\
            isDarkMode = !isDarkMode;\
            if (isDarkMode) \{\
                document.documentElement.classList.add('dark');\
                themeIcon.className = 'ph ph-sun text-yellow-400 text-lg';\
                themeText.textContent = i18n[currentLang].themeLight;\
            \} else \{\
                document.documentElement.classList.remove('dark');\
                themeIcon.className = 'ph ph-moon text-slate-500 text-lg';\
                themeText.textContent = i18n[currentLang].themeDark;\
            \}\
        \});\
\
        // --- Help Modal ---\
        helpBtn.addEventListener('click', () => helpModal.classList.remove('hidden'));\
        closeHelpBtn.addEventListener('click', () => helpModal.classList.add('hidden'));\
        helpModal.addEventListener('click', (e) => \{\
            if (e.target === helpModal) helpModal.classList.add('hidden');\
        \});\
\
        // --- Drag & Drop Implementation ---\
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => \{\
            dropZone.addEventListener(eventName, preventDefaults, false);\
        \});\
\
        function preventDefaults(e) \{\
            e.preventDefault();\
            e.stopPropagation();\
        \}\
\
        ['dragenter', 'dragover'].forEach(eventName => \{\
            dropZone.addEventListener(eventName, () => dropZone.classList.add('drop-zone-active'), false);\
        \});\
\
        ['dragleave', 'drop'].forEach(eventName => \{\
            dropZone.addEventListener(eventName, () => dropZone.classList.remove('drop-zone-active'), false);\
        \});\
\
        dropZone.addEventListener('drop', (e) => \{\
            const dt = e.dataTransfer;\
            const files = dt.files;\
            if (files.length > 0) handleFile(files[0]);\
        \});\
\
        fileInput.addEventListener('change', function() \{\
            if (this.files.length > 0) handleFile(this.files[0]);\
        \});\
\
        function handleFile(file) \{\
            if (!file.type.startsWith('image/')) \{\
                showToast(i18n[currentLang].toastFormatError, 'error');\
                return;\
            \}\
\
            currentMimeType = file.type;\
            const reader = new FileReader();\
            \
            reader.onload = function(e) \{\
                imagePreview.src = e.target.result;\
                imagePreview.classList.remove('hidden');\
                uploadPlaceholder.classList.add('hidden');\
                \
                currentBase64 = e.target.result.split(',')[1];\
                analyzeBtn.disabled = false;\
                \
                englishResult.value = '';\
                chineseResult.value = '';\
                copyEnBtn.disabled = true;\
                copyZhBtn.disabled = true;\
                downloadBtn.disabled = true;\
            \}\
            reader.readAsDataURL(file);\
        \}\
\
        // --- API & Retry Logic ---\
        async function fetchWithRetry(url, options, maxRetries = 5) \{\
            const delays = [1000, 2000, 4000, 8000, 16000];\
            for (let i = 0; i <= maxRetries; i++) \{\
                try \{\
                    const response = await fetch(url, options);\
                    if (!response.ok) \{\
                        const errorData = await response.json().catch(() => (\{\}));\
                        throw new Error(errorData.error?.message || `HTTP Error: $\{response.status\}`);\
                    \}\
                    return await response.json();\
                \} catch (err) \{\
                    if (i === maxRetries) throw err;\
                    await new Promise(resolve => setTimeout(resolve, delays[i]));\
                \}\
            \}\
        \}\
\
        // --- Analysis Execution ---\
        analyzeBtn.addEventListener('click', async () => \{\
            if (!currentBase64 || !currentMimeType) return;\
\
            // UI State updates\
            analyzeBtn.disabled = true;\
            loadingOverlay.classList.remove('hidden');\
            englishResult.value = '';\
            chineseResult.value = '';\
            copyEnBtn.disabled = true;\
            copyZhBtn.disabled = true;\
            downloadBtn.disabled = true;\
\
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=$\{apiKey\}`;\
            \
            let promptText = "Please analyze this image in extreme detail and generate a highly descriptive, comprehensive text-to-image prompt (suitable for Midjourney or Stable Diffusion).\\n";\
            \
            let frameworks = [];\
            if (detailCheck.checked) \{\
                frameworks.push(`- Subject/Character & Action/Pose (e.g., posture, gestures, interaction).\\n- Clothing/Accessories (e.g., dressing style, outfit, jewelry, props).\\n- Scene/Atmosphere (e.g., location, time, weather, environment decorations, lighting/shadows).\\n- Camera/Style (e.g., focal length, aperture, composition, shot type, style, viewing angle).`);\
            \}\
            if (facialCheck.checked) \{\
                frameworks.push(`- Detailed Facial Features (MUST include specific descriptive terms for: Race/Ethnicity, Face Shape (e.g. oval, square, high cheekbones), Skin Color, Hair Color/Style (e.g. ombre, messy waves, pixie cut), Eye Shape (e.g. fox eyes, almond, doe eyes), Pupil Color/Shape, Forehead, Cheeks, Chin, Ears (e.g. elf ears, protruding), Nose Shape/Wings/Tip (e.g. aquiline, button nose), Lips (e.g. cherry lips, downturned), Eyebrows (e.g. arched, bushy)).`);\
            \}\
\
            if (frameworks.length > 0) \{\
                promptText += `YOU MUST strictly use the following framework to structure your prompt and provide rich, exhaustive details:\\n$\{frameworks.join('\\n')\}\\n`;\
            \} else \{\
                promptText += `Focus strictly on the subject, action, lighting, camera angle, medium, style, and mood.\\n`;\
            \}\
\
            promptText += `The resulting prompt must be lengthy and highly descriptive to allow perfect recreation of the original image.\\nOutput ONLY a valid JSON object with two keys:\\n"english": "the highly detailed English prompt (comma separated keywords preferred)",\\n"chinese": "the Traditional Chinese translation of the prompt"\\nDo not include any other text or markdown formatting.`;\
\
            const payload = \{\
                contents: [\{\
                    role: "user",\
                    parts: [\
                        \{ text: promptText \},\
                        \{ inlineData: \{ mimeType: currentMimeType, data: currentBase64 \} \}\
                    ]\
                \}]\
            \};\
\
            try \{\
                const data = await fetchWithRetry(url, \{\
                    method: 'POST',\
                    headers: \{ 'Content-Type': 'application/json' \},\
                    body: JSON.stringify(payload)\
                \});\
\
                const generatedText = data.candidates?.[0]?.content?.parts?.[0]?.text;\
\
                if (generatedText) \{\
                    try \{\
                        const cleanJson = generatedText.replace(/```json/g, '').replace(/```/g, '').trim();\
                        const resultObj = JSON.parse(cleanJson);\
                        \
                        englishResult.value = resultObj.english || '';\
                        chineseResult.value = resultObj.chinese || '';\
                        \
                        copyEnBtn.disabled = false;\
                        copyZhBtn.disabled = false;\
                        downloadBtn.disabled = false;\
                        \
                        const msgKey = (detailCheck.checked || facialCheck.checked) ? 'toastAnalysisDone' : 'toastGenerationDone';\
                        showToast(i18n[currentLang][msgKey], 'success');\
                    \} catch (e) \{\
                        englishResult.value = generatedText;\
                        copyEnBtn.disabled = false;\
                        downloadBtn.disabled = false;\
                        showToast(i18n[currentLang].toastAnalysisError, 'success');\
                    \}\
                \} else \{\
                    throw new Error("Cannot retrieve complete response from API.");\
                \}\
            \} catch (error) \{\
                console.error("API Error:", error);\
                englishResult.value = `API Request Error / API \uc0\u35531 \u27714 \u30332 \u29983 \u37679 \u35492 :\\n$\{error.message\}`;\
                showToast('Generation failed. / \uc0\u29983 \u25104 \u22833 \u25943 \u12290 ', 'error');\
            \} finally \{\
                analyzeBtn.disabled = false;\
                loadingOverlay.classList.add('hidden');\
            \}\
        \});\
\
        // --- Clipboard & Download Functionality ---\
        function copyToClipboard(text) \{\
            const textArea = document.createElement("textarea");\
            textArea.value = text;\
            textArea.style.position = "fixed";\
            textArea.style.left = "-999999px";\
            textArea.style.top = "-999999px";\
            document.body.appendChild(textArea);\
            textArea.focus();\
            textArea.select();\
            \
            try \{\
                document.execCommand('copy');\
                showToast(i18n[currentLang].toastCopySuccess, 'success');\
            \} catch (err) \{\
                showToast(i18n[currentLang].toastCopyFail, 'error');\
            \} finally \{\
                textArea.remove();\
            \}\
        \}\
\
        copyEnBtn.addEventListener('click', () => \{\
            if (englishResult.value) copyToClipboard(englishResult.value);\
        \});\
\
        copyZhBtn.addEventListener('click', () => \{\
            if (chineseResult.value) copyToClipboard(chineseResult.value);\
        \});\
\
        downloadBtn.addEventListener('click', () => \{\
            if (!englishResult.value) return;\
            \
            const content = `\uc0\u12304 English Prompt\u12305 \\n$\{englishResult.value\}\\n\\n\u12304 \u20013 \u25991 \u23565 \u29031 \u12305 \\n$\{chineseResult.value\}`;\
            const blob = new Blob([content], \{ type: 'text/plain;charset=utf-8' \});\
            const url = URL.createObjectURL(blob);\
            const a = document.createElement('a');\
            \
            a.href = url;\
            a.download = `Prompt_$\{new Date().getTime()\}.txt`;\
            document.body.appendChild(a);\
            a.click();\
            \
            setTimeout(() => \{\
                document.body.removeChild(a);\
                window.URL.revokeObjectURL(url);\
            \}, 0);\
            \
            showToast(i18n[currentLang].toastDownload, 'success');\
        \});\
\
        // --- Toast Notifications ---\
        let toastTimeout;\
        function showToast(message, type = 'success') \{\
            toastMsg.textContent = message;\
            \
            const icon = toast.querySelector('i');\
            if (type === 'success') \{\
                icon.className = 'ph ph-check-circle text-green-400 dark:text-green-500 text-xl';\
            \} else \{\
                icon.className = 'ph ph-warning-circle text-red-400 dark:text-red-500 text-xl';\
            \}\
\
            toast.classList.remove('opacity-0', 'translate-y-4');\
            toast.classList.add('opacity-100', 'translate-y-0');\
\
            clearTimeout(toastTimeout);\
            toastTimeout = setTimeout(() => \{\
                toast.classList.remove('opacity-100', 'translate-y-0');\
                toast.classList.add('opacity-0', 'translate-y-4');\
            \}, 3000);\
        \}\
    </script>\
